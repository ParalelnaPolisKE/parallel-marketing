# =============================================================================
# Postiz Environment Configuration
# Skopíruj tento súbor ako postiz.env a vyplň skutočné hodnoty.
# NIKDY necommituj postiz.env do repozitára!
# =============================================================================

# --- Core ---
MAIN_URL=https://postiz.local.ppke.sk
FRONTEND_URL=https://postiz.local.ppke.sk
NEXT_PUBLIC_BACKEND_URL=https://postiz.local.ppke.sk/api
JWT_SECRET=ZMEN_MA_na_nahodny_retazec_min_32_znakov

# --- Database ---
DATABASE_URL=postgresql://postiz:ZMEN_MA@postiz-postgres:5432/postiz

# --- Redis ---
REDIS_URL=redis://postiz-redis:6379

# --- Temporal ---
TEMPORAL_ADDRESS=temporal:7233

# --- Storage ---
STORAGE_PROVIDER=local

# --- Authentik OIDC ---
POSTIZ_GENERIC_OAUTH=true
NEXT_PUBLIC_POSTIZ_OAUTH_DISPLAY_NAME=Authentik
NEXT_PUBLIC_POSTIZ_OAUTH_LOGO_URL=https://auth.local.ppke.sk/static/dist/assets/icons/icon.png
POSTIZ_OAUTH_URL=https://auth.local.ppke.sk/application/o/postiz/
POSTIZ_OAUTH_AUTH_URL=https://auth.local.ppke.sk/application/o/authorize/
POSTIZ_OAUTH_TOKEN_URL=https://auth.local.ppke.sk/application/o/token/
POSTIZ_OAUTH_USERINFO_URL=https://auth.local.ppke.sk/application/o/userinfo/
POSTIZ_OAUTH_CLIENT_ID=ZMEN_MA
POSTIZ_OAUTH_CLIENT_SECRET=ZMEN_MA

